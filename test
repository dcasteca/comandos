# Variables
DOMAIN_NAME="api.dev.integration.appst.ambientesbc.com"
REGION="us-east-1"   # Ajusta si hace falta

# 1) Listar mappings y mostrarlos (opcional)
aws apigatewayv2 get-api-mappings \
  --domain-name "$DOMAIN_NAME" \
  --region "$REGION"

# 2) Eliminar todos los mappings del dominio
for ID in $(aws apigatewayv2 get-api-mappings \
              --domain-name "$DOMAIN_NAME" \
              --region "$REGION" \
              --query 'Items[].ApiMappingId' \
              --output text); do
  echo "Eliminando API mapping: $ID"
  aws apigatewayv2 delete-api-mapping \
    --domain-name "$DOMAIN_NAME" \
    --api-mapping-id "$ID" \
    --region "$REGION"
done

echo "✅ Completado para $DOMAIN_NAME"
